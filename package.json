{
  "name": "animal-farm-frontend-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next out tsconfig.tsbuildinfo",
    "dev": "next dev",
    "build": "npm run clean && next build && node scripts/append-cache-bust.mjs",
    "build:cloudflare": "NEXT_PUBLIC_DATA_MODE=cloudflare npm run build",
    "verify:export": "node scripts/verify-export.mjs",
    "deploy:cloudflare": "npm run build:cloudflare && npm run verify:export && npx wrangler pages deploy out --project-name animal-farm-vocab --branch main",
    "preview": "serve out",
    "start": "npm run preview"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.9.2",
    "lucide-react": "^0.511.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "serve": "^14.2.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
